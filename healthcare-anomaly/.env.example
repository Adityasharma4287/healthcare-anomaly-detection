# ─── Kafka Configuration ──────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=patient-vitals
KAFKA_GROUP_ID=anomaly-detector-group

# ─── PostgreSQL Configuration ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthcare_monitoring
DB_USER=healthcare_admin
DB_PASSWORD=your_secure_password_here

# ─── Flask Configuration ──────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_change_in_production

# ─── Email Notification Configuration ────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=admin@hospital.com

# ─── ML Model Configuration ───────────────────────────────────────────────────
MODEL_PATH=./models/autoencoder_model.h5
IFOREST_PATH=./models/isolation_forest.pkl
SCALER_PATH=./models/scaler.pkl
ANOMALY_THRESHOLD_HIGH=0.70
ANOMALY_THRESHOLD_MEDIUM=0.40
